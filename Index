<script>
// ═══════════════════════════════════════════════════════
//  CONFIGURATION
// ═══════════════════════════════════════════════════════
// Paste your Apps Script Web App URL here after deployment,
// OR enter it via the Setup modal (⚙ button in nav)
let APPS_SCRIPT_URL = localStorage.getItem('appsScriptUrl') || '';

const HALLS = ['HY One','HY Nine','Sriman'];
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const DAYS   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

// Local cache: { 'HY One': { '2025-05-15': { AM:'Blocked', PM:'Available' } } }
let localBookings = JSON.parse(localStorage.getItem('hb_bookings') || '{}');

function saveLocalBookings() {
  localStorage.setItem('hb_bookings', JSON.stringify(localBookings));
}

function getSlotStatus(hall, dateStr, slot) {
  return (localBookings[hall]?.[dateStr]?.[slot]) || 'Available';
}

function setSlotStatus(hall, dateStr, slot, status) {
  if (!localBookings[hall]) localBookings[hall] = {};
  if (!localBookings[hall][dateStr]) localBookings[hall][dateStr] = {};
  localBookings[hall][dateStr][slot] = status;
  saveLocalBookings();
}

// ═══════════════════════════════════════════════════════
//  GOOGLE LOGIN (simulated OAuth consent flow)
// ═══════════════════════════════════════════════════════
let currentUser = JSON.parse(sessionStorage.getItem('hb_user') || 'null');

function handleGoogleLogin() {
  // In production: replace with real Google OAuth / Google Identity Services
  // For self-hosted use, this opens a Google OAuth consent screen
  const CLIENT_ID = ''; // ← Paste your Google OAuth Client ID here

  if (CLIENT_ID) {
    // Real OAuth flow
    google.accounts.id.initialize({
      client_id: CLIENT_ID,
      callback: onGoogleCredential,
      auto_select: false,
    });
    google.accounts.id.prompt();
  } else {
    // Demo mode — simulate login with a placeholder user
    simulateLogin();
  }
}

function onGoogleCredential(response) {
  // Decode JWT
  const payload = JSON.parse(atob(response.credential.split('.')[1]));
  currentUser = { name: payload.name, email: payload.email, picture: payload.picture };
  sessionStorage.setItem('hb_user', JSON.stringify(currentUser));
  showMainApp();
}

function simulateLogin() {
  currentUser = {
    name: 'Staff User',
    email: 'staff@example.com',
    picture: null
  };
  sessionStorage.setItem('hb_user', JSON.stringify(currentUser));
  showMainApp();
}

function showMainApp() {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('main-app').style.display = 'block';
  renderUserBar();
  checkScriptConfig();
}

function renderUserBar() {
  if (!currentUser) return;
  const bar = document.getElementById('user-info-bar');
  const avatar = currentUser.picture
