function getHinduInfo(dateStr) { return HINDU_CALENDAR[dateStr] || null; }

// ═══════════════════════════════════════════════════════
//  OVERVIEW CALENDAR
// ═══════════════════════════════════════════════════════
let ovMonth = null, ovYear = null, ovHall = null;

async function renderOverviewCalendar(monthOverride, yearOverride) {
  const hall = document.getElementById('ov-hall').value;
  if (!hall) { alert('Please select a Convention Hall.'); return; }

  if (monthOverride !== undefined) {
    let m = monthOverride, y = yearOverride;
    if (m < 0)  { m = 11; y--; }
    if (m > 11) { m = 0;  y++; }
    ovMonth = m; ovYear = y; ovHall = hall;
    document.getElementById('ov-month').value = m;
    document.getElementById('ov-year').value  = y;
  } else {
    const mSel = document.getElementById('ov-month').value;
    const ySel = document.getElementById('ov-year').value;
    if (!mSel || !ySel) { alert('Please select Month and Year.'); return; }
    ovMonth = parseInt(mSel); ovYear = parseInt(ySel); ovHall = hall;
  }

  // Show loading
  document.getElementById('overview-calendar').innerHTML =
    `<div class="cal-loading"><div class="spinner"></div>Loading ${hall} calendar…</div>`;

  // Fetch from Google Sheets if configured
  if (APPS_SCRIPT_URL) {
    await fetchFromSheet(hall, ovYear, ovMonth);
    // Also prefetch prev/next
    let pm = ovMonth-1, py = ovYear; if(pm<0){pm=11;py--;}
    let nm = ovMonth+1, ny = ovYear; if(nm>11){nm=0;ny++;}
    fetchFromSheet(hall, py, pm);
    fetchFromSheet(hall, ny, nm);
  }

  let prevM = ovMonth-1, prevY = ovYear; if(prevM<0){prevM=11;prevY--;}
  let nextM = ovMonth+1, nextY = ovYear; if(nextM>11){nextM=0;nextY++;}

  const html =
    `<div class="three-cal-nav">
      <a href="#" onclick="renderOverviewCalendar(${ovMonth-1},${ovYear});return false;">&#8249;&nbsp;${MONTHS[prevM]} ${prevY}</a>
      <span class="nav-center">${ovHall} &mdash; ${MONTHS[ovMonth]} ${ovYear}</span>
      <a href="#" onclick="renderOverviewCalendar(${ovMonth+1},${ovYear});return false;">${MONTHS[nextM]} ${nextY}&nbsp;&#8250;</a>
    </div>
    <div class="three-cal-grid">
      ${buildMonthBlock(prevM, prevY, false)}
      ${buildMonthBlock(ovMonth, ovYear, true)}
      ${buildMonthBlock(nextM, nextY, false)}
    </div>`;

  document.getElementById('overview-calendar').innerHTML = html;
  document.getElementById('cal-legend').style.display = 'flex';
}

function buildMonthBlock(month, year, isCurrent) {
  const firstDay    = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month+1, 0).getDate();
  const hall        = ovHall || '';
  const hlClass     = isCurrent ? 'current-month' : '';

  let rows = '<tr>', col = 0;
  for (let i = 0; i < firstDay; i++) { rows += '<td class="empty"></td>'; col++; }

  for (let d = 1; d <= daysInMonth; d++) {
    const mm      = String(month+1).padStart(2,'0');
    const dd      = String(d).padStart(2,'0');
    const dateStr = `${year}-${mm}-${dd}`;
    const amSt    = getSlotStatus(hall, dateStr, 'AM');
    const pmSt    = getSlotStatus(hall, dateStr, 'PM');
    const bankHol = getBankHoliday(year, month, d);
    const hindu   = getHinduInfo(dateStr);

    const amCell = (amSt==='Available'||amSt==='Tentative')
      ? `<div class="cal-slot ${amSt.toLowerCase()}"><a href="#" title="${amSt}—AM" onclick="goToBooking('${dateStr}','AM');return false;">AM</a></div>`
      : `<div class="cal-slot ${amSt.toLowerCase()}">AM</div>`;
    const pmCell = (pmSt==='Available'||pmSt==='Tentative')
      ? `<div class="cal-slot ${pmSt.toLowerCase()}"><a href="#" title="${pmSt}—PM" onclick="goToBooking('${dateStr}','PM');return false;">PM</a></div>`
      : `<div class="cal-slot ${pmSt.toLowerCase()}">PM</div>`;

    const bankTag  = bankHol ? `<div class="cal-holiday-tag bank" title="Bank Holiday: ${bankHol}">🏦 ${bankHol}</div>` : '';
    const hinduTag = hindu   ? `<div class="cal-holiday-tag hindu" title="${hindu.tithi}: ${hindu.festival}">🕉 ${hindu.festival}</div>` : '';

    rows += `<td class="${(bankHol||hindu)?'has-holiday':''}">
      <div class="cal-date-header">
        <div class="cal-date-num">${d}</div>
        ${bankTag}${hinduTag}
      </div>
      <div class="cal-slots">${amCell}${pmCell}</div>
    </td>`;
    col++;
    if (col===7 && d!==daysInMonth) { rows+='</tr><tr>'; col=0; }
  }
  while (col%7!==0) { rows+='<td class="empty"></td>'; col++; }
  rows += '</tr>';

  return `<div class="cal-month-block ${hlClass}">
    <div class="cal-month-title">${MONTHS[month]} ${year}</div>
    <table class="calendar">
      <thead><tr>${DAYS.map(d=>`<th>${d}</th>`).join('')}</tr></thead>
      <tbody>${rows}</tbody>
    </table>
  </div>`;
}

// ═══════════════════════════════════════════════════════
//  DATE STATUS
// ═══════════════════════════════════════════════════════
async function checkDateStatus() {
  const hall = document.getElementById('date-hall').value;
  const val  = document.getElementById('date-picker').value;
  if (!hall) { alert('Please select a Convention Hall.'); return; }
  if (!val)  { alert('Please select a date.'); return; }

  if (APPS_SCRIPT_URL) await fetchFromSheet(hall, ...val.split('-').slice(0,2).map((v,i)=>i===1?parseInt(v)-1:parseInt(v)));

  const [y, m, d] = val.split('-');
  document.getElementById('date-result-heading').textContent =
    `${hall} — ${parseInt(d)} ${MONTHS[parseInt(m)-1]} ${y}`;

  let html = '';
  ['AM','PM'].forEach(slot => {
    const st  = getSlotStatus(hall, val, slot);
    const cls = st.toLowerCase();
    const isLink = st==='Available'||st==='Tentative';
    html += `<div class="slot-status-row">
      <span class="slot-name">${slot}</span>
      ${isLink
        ? `<a class="status-link" href="#" onclick="goToBooking('${val}','${slot}');return false;"><span class="status-badge status-${cls}">${st}</span></a>`
        : `<span class="status-badge status-${cls}">${st}</span>`}
    </div>`;
  });

  document.getElementById('date-result-slots').innerHTML = html;
  document.getElementById('date-status-result').classList.add('show');
}

