  "2026-01-14":{tithi:"Sankranti",festival:"Makar Sankranti"},"2026-02-15":{tithi:"Chaturdashi",festival:"Maha Shivaratri"},"2026-03-03":{tithi:"Pratipada",festival:"Holi"},"2026-03-28":{tithi:"Navami",festival:"Ram Navami"},"2026-04-01":{tithi:"Purnima",festival:"Hanuman Jayanti"},"2026-05-01":{tithi:"Purnima",festival:"Buddha Purnima"},"2026-06-28":{tithi:"Purnima",festival:"Guru Purnima"},"2026-08-05":{tithi:"Ashtami",festival:"Janmashtami"},"2026-08-17":{tithi:"Chaturthi",festival:"Ganesh Chaturthi"},"2026-10-08":{tithi:"Dashami",festival:"Dussehra"},"2026-11-08":{tithi:"Amavasya",festival:"Diwali"},"2026-11-09":{tithi:"Pratipada",festival:"Govardhan Puja"},"2026-11-10":{tithi:"Dwitiya",festival:"Bhai Dooj"},"2026-11-25":{tithi:"Purnima",festival:"Kartik Purnima"},
