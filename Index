if (currentUser) { showMainApp(); }

// ═══════════════════════════════════════════════════════
//  APPS SCRIPT / GOOGLE SHEETS SYNC
// ═══════════════════════════════════════════════════════
function saveScriptUrl() {
  const url = document.getElementById('script-url-input').value.trim();
  if (!url.startsWith('https://script.google.com')) {
    alert('Please enter a valid Apps Script URL.');
    return;
  }
  APPS_SCRIPT_URL = url;
  localStorage.setItem('appsScriptUrl', url);
  document.getElementById('script-modal').style.display = 'none';
  document.getElementById('script-config-banner').style.display = 'none';
  alert('✅ Apps Script URL saved. Calendar will now sync from Google Sheets.');
}

async function fetchFromSheet(hall, year, month) {
  if (!APPS_SCRIPT_URL) return null;
  try {
    const url = `${APPS_SCRIPT_URL}?hall=${encodeURIComponent(hall)}&year=${year}&month=${month}`;
    const res  = await fetch(url);
    const data = await res.json();
    if (data.success && data.data) {
      // Merge sheet data into local cache
      if (!localBookings[hall]) localBookings[hall] = {};
      Object.assign(localBookings[hall], data.data);
      saveLocalBookings();
      return data.data;
    }
  } catch(e) { console.warn('Sheet fetch failed:', e); }
  return null;
}

// ═══════════════════════════════════════════════════════
//  NAVIGATION
// ═══════════════════════════════════════════════════════
function showPage(pageId, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(pageId).classList.add('active');
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  else {
    document.querySelectorAll('nav button').forEach(b => {
      if ((b.getAttribute('onclick') || '').includes(pageId)) b.classList.add('active');
    });
  }
}

function resetApp() {
  if (!confirm('Clear all local booking data and reset?')) return;
  localBookings = {};
  saveLocalBookings();
  document.getElementById('overview-calendar').innerHTML = '';
