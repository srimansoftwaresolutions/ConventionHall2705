function getBankHoliday(year, month, day) {
  const key = `${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
  return (BANK_HOLIDAYS_YEARLY[year]||{})[key] || BANK_HOLIDAYS_FIXED[key] || null;
