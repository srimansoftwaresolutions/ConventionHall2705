<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>HY One – HY Nine – Sriman | Booking System</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<!-- Google Identity Services -->
<script src="https://accounts.google.com/gsi/client" async defer></script>
<style>
:root {
  --gold:#c9a84c; --gold-light:#e8c97a;
  --dark:#1a1a2e; --dark2:#16213e; --dark3:#0f3460;
  --cream:#fdf6e3; --cream2:#f5ead0; --text:#2c2c2c;
  --available:#2d7a4f; --available-bg:#d4f5e0;
  --tentative:#b36a00; --tentative-bg:#ffe8b0;
  --blocked:#b52b2b; --blocked-bg:#fdd5d5;
  --border:#d6c89a;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);min-height:100vh;}

/* ── LOGIN SCREEN ── */
#login-screen {
  min-height:100vh;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:linear-gradient(135deg,var(--dark) 0%,var(--dark3) 100%);
  position:relative;overflow:hidden;
}
#login-screen::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(45deg,transparent,transparent 40px,rgba(201,168,76,0.04) 40px,rgba(201,168,76,0.04) 80px);
}
.login-card{
  position:relative;
  background:rgba(255,255,255,0.06);
  border:2px solid var(--gold);
  border-radius:12px;
  padding:52px 48px 44px;
  text-align:center;
  max-width:420px;width:90%;
  backdrop-filter:blur(6px);
}
.login-logo{font-size:3rem;margin-bottom:18px;}
.login-title{
  font-family:'Playfair Display',serif;
  font-size:1.6rem;font-weight:900;
  color:var(--gold-light);letter-spacing:1px;
  margin-bottom:6px;line-height:1.3;
}
.login-sub{font-size:0.9rem;color:rgba(255,255,255,0.6);margin-bottom:32px;letter-spacing:0.3px;}
.login-divider{
  border:none;border-top:1px solid rgba(201,168,76,0.3);
  margin:0 0 28px;
}
#g_id_onload{display:none;}
.google-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:12px;
  background:#fff;color:#3c4043;
  border:2px solid var(--gold);border-radius:6px;
  padding:13px 28px;font-size:0.95rem;font-weight:600;
  cursor:pointer;width:100%;transition:all 0.2s;
  font-family:'DM Sans',sans-serif;letter-spacing:0.3px;
}
.google-btn:hover{background:var(--gold-light);border-color:var(--gold);}
.google-btn svg{width:20px;height:20px;flex-shrink:0;}
.login-note{margin-top:20px;font-size:0.78rem;color:rgba(255,255,255,0.4);}

/* ── MAIN APP (hidden until logged in) ── */
#main-app{display:none;}

/* ── HEADER ── */
.site-header{
  background:linear-gradient(135deg,var(--dark) 0%,var(--dark3) 100%);
  padding:18px 40px 14px;text-align:center;
  border-bottom:3px solid var(--gold);position:relative;overflow:hidden;
}
.site-header::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(45deg,transparent,transparent 30px,rgba(201,168,76,0.04) 30px,rgba(201,168,76,0.04) 60px);
}
.header-inner{position:relative;display:flex;align-items:center;justify-content:space-between;}
.site-header h1{
  font-family:'Playfair Display',serif;font-weight:900;
  color:var(--gold-light);letter-spacing:2px;position:relative;
  font-size:1.6rem;line-height:1.25;text-align:center;flex:1;
}
.site-header h1 .sub{display:block;font-size:1rem;color:rgba(255,255,255,0.75);letter-spacing:3px;font-weight:400;margin-top:2px;}
.user-info{
  display:flex;align-items:center;gap:10px;
  font-size:0.82rem;color:rgba(255,255,255,0.75);
  flex-shrink:0;
}
.user-avatar{
  width:34px;height:34px;border-radius:50%;border:2px solid var(--gold);
  object-fit:cover;
}
.user-avatar-placeholder{
  width:34px;height:34px;border-radius:50%;border:2px solid var(--gold);
  background:var(--gold);color:var(--dark);font-weight:700;font-size:0.85rem;
  display:flex;align-items:center;justify-content:center;
}
.logout-btn{
  background:none;border:1px solid rgba(201,168,76,0.5);border-radius:4px;
  color:rgba(255,255,255,0.65);font-size:0.75rem;padding:4px 10px;cursor:pointer;
  font-family:'DM Sans',sans-serif;transition:all 0.2s;
}
.logout-btn:hover{border-color:var(--gold);color:var(--gold-light);}

/* ── NAV ── */
nav{
  background:var(--dark2);display:flex;justify-content:center;
  gap:6px;padding:12px 20px;border-bottom:2px solid var(--gold);flex-wrap:wrap;
}
nav button{
  font-family:'DM Sans',sans-serif;font-size:0.92rem;font-weight:600;
  letter-spacing:1px;text-transform:uppercase;padding:9px 24px;
  border:2px solid var(--gold);background:transparent;
  color:var(--gold-light);cursor:pointer;border-radius:2px;transition:all 0.2s;
}
nav button:hover,nav button.active{background:var(--gold);color:var(--dark);}
nav button.reset-btn{border-color:#e57373;color:#ef9a9a;}
nav button.reset-btn:hover{background:#e57373;color:#fff;}

/* ── PAGES ── */
.page{display:none;padding:32px 36px;max-width:1280px;margin:0 auto;}
.page.active{display:block;animation:fadeIn 0.3s;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}

/* ── HOME PAGE ── */
#home-page .nav-cards{
  display:flex;gap:24px;margin-top:24px;flex-wrap:wrap;justify-content:center;
}
.nav-card{
  background:#fff;border:2px solid var(--border);border-radius:8px;
  padding:32px 28px;width:220px;cursor:pointer;transition:all 0.25s;text-align:center;
}
.nav-card:hover{border-color:var(--gold);transform:translateY(-4px);box-shadow:0 8px 24px rgba(201,168,76,0.2);}
.nav-card .icon{font-size:2.4rem;margin-bottom:12px;}
.nav-card h3{font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--dark3);margin-bottom:8px;}
.nav-card p{font-size:0.85rem;color:#666;}

/* ── SECTION HEADINGS ── */
.section-title{
  font-family:'Playfair Display',serif;font-size:1.6rem;color:var(--dark3);
  margin-bottom:24px;padding-bottom:10px;border-bottom:2px solid var(--gold);
}

/* ── FORM ELEMENTS ── */
.form-group{margin-bottom:18px;}
.form-group label{display:block;font-weight:600;font-size:0.85rem;margin-bottom:5px;color:var(--dark3);text-transform:uppercase;letter-spacing:0.5px;}
.form-group select,.form-group input[type="date"],.form-group input[type="text"],.form-group input[type="number"]{
  width:100%;padding:9px 12px;border:2px solid var(--border);border-radius:4px;
  font-family:'DM Sans',sans-serif;font-size:0.95rem;background:#fff;color:var(--text);transition:border-color 0.2s;
}
.form-group select:focus,.form-group input:focus{outline:none;border-color:var(--gold);}
.row{display:flex;gap:20px;flex-wrap:wrap;}
.row .form-group{flex:1;min-width:140px;}

/* ── BUTTONS ── */
.btn{
  font-family:'DM Sans',sans-serif;font-size:0.92rem;font-weight:600;
  padding:10px 24px;border:2px solid transparent;border-radius:4px;
  cursor:pointer;text-transform:uppercase;letter-spacing:0.8px;transition:all 0.2s;
}
.btn-primary{background:var(--dark3);color:var(--gold-light);border-color:var(--dark3);}
.btn-primary:hover{background:var(--dark);border-color:var(--gold);}
.btn-check{background:var(--dark3);color:#fff;}
.btn-check:hover{background:var(--dark);}
.btn-reset2{background:#555;color:#fff;}
.btn-reset2:hover{background:#333;}
.btn-group{display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;}

/* ── STATUS BADGE ── */
.status-badge{
  display:inline-block;padding:4px 14px;border-radius:3px;
  font-weight:700;font-size:0.82rem;text-transform:uppercase;letter-spacing:1px;
}
.status-available{background:var(--available-bg);color:var(--available);}
.status-tentative{background:var(--tentative-bg);color:var(--tentative);}
.status-blocked{background:var(--blocked-bg);color:var(--blocked);}
.status-link{text-decoration:none;cursor:pointer;}
.status-link:hover .status-badge{filter:brightness(0.92);}

/* ── OVERVIEW CONTROLS ── */
.overview-controls{
  background:#fff;border:2px solid var(--border);border-radius:6px;
  padding:20px 24px;margin-bottom:24px;
  display:flex;gap:20px;align-items:flex-end;flex-wrap:wrap;
}
.overview-controls .form-group{margin-bottom:0;min-width:140px;}
.overview-controls .btn{margin-bottom:0;}

/* ── 3-MONTH CALENDAR ── */
.three-cal-nav{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:18px;padding:11px 16px;
  background:linear-gradient(135deg,var(--dark) 0%,var(--dark3) 100%);
  border-radius:6px;border:2px solid var(--gold);
}
.three-cal-nav a{
  font-family:'Playfair Display',serif;font-size:0.92rem;font-weight:700;
  color:var(--gold-light);text-decoration:none;padding:6px 14px;
  border:2px solid var(--gold);border-radius:4px;
  background:rgba(255,255,255,0.07);transition:all 0.2s;
}
.three-cal-nav a:hover{background:var(--gold);color:var(--dark);}
.three-cal-nav .nav-center{
  font-family:'Playfair Display',serif;font-size:1.05rem;
  font-weight:700;color:var(--gold-light);letter-spacing:1px;
}
.three-cal-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;align-items:start;}
.cal-month-block{background:#fff;border:2px solid var(--border);border-radius:6px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);}
.cal-month-block.current-month{border-color:var(--gold);box-shadow:0 4px 20px rgba(201,168,76,0.22);}
.cal-month-title{
  font-family:'Playfair Display',serif;font-size:0.92rem;font-weight:700;
  color:#fff;background:var(--dark3);padding:8px 10px;
  text-align:center;letter-spacing:1px;border-bottom:2px solid var(--border);
}
.cal-month-block.current-month .cal-month-title{
  background:linear-gradient(135deg,var(--dark) 0%,var(--dark3) 100%);
  color:var(--gold-light);border-bottom-color:var(--gold);
}
table.calendar{width:100%;border-collapse:collapse;table-layout:fixed;}
table.calendar th{
  background:var(--dark2);color:var(--gold-light);padding:5px 2px;
  font-size:0.66rem;font-weight:700;letter-spacing:0.3px;
  text-align:center;border:1px solid #2a3a5c;
}
table.calendar td{border:1px solid var(--border);vertical-align:top;width:calc(100% / 7);padding:0;background:#fff;}
table.calendar td.empty{background:var(--cream2);border:1px solid var(--border);}
.cal-date-header{display:flex;flex-direction:column;border-bottom:2px solid var(--border);background:var(--cream2);}
.cal-date-num{font-weight:700;font-size:0.7rem;padding:3px 4px 1px;color:var(--dark3);text-align:center;line-height:1.2;}
td.has-holiday .cal-date-num{color:#b52b2b;}
.cal-holiday-tag{
  font-size:0.5rem;font-weight:700;line-height:1.2;text-align:center;
  padding:1px 2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.cal-holiday-tag.bank{background:#1a237e;color:#fff;}
.cal-holiday-tag.hindu{background:#f57f17;color:#fff;}
.cal-slots{display:flex;flex-direction:column;}
.cal-slot{
  display:flex;align-items:center;justify-content:center;
  min-height:22px;font-size:0.58rem;font-weight:800;
  color:rgba(0,0,0,0.4);border-bottom:1px solid rgba(0,0,0,0.1);
  cursor:default;transition:filter 0.15s;
}
.cal-slot:last-child{border-bottom:none;}
.cal-slot.available{background:var(--available-bg);cursor:pointer;}
.cal-slot.available:hover{filter:brightness(0.9);}
.cal-slot.tentative{background:var(--tentative-bg);cursor:pointer;}
.cal-slot.tentative:hover{filter:brightness(0.9);}
.cal-slot.blocked{background:var(--blocked-bg);cursor:not-allowed;}
.cal-slot a{
  display:flex;align-items:center;justify-content:center;
  width:100%;height:100%;min-height:22px;
  color:rgba(0,0,0,0.4);text-decoration:none;font-size:0.58rem;font-weight:800;
}

/* ── LEGEND ── */
.cal-legend{
  display:flex;gap:18px;margin-top:16px;flex-wrap:wrap;
  justify-content:center;font-size:0.82rem;
  padding:10px 18px;background:#fff;border:1px solid var(--border);border-radius:6px;
}
.legend-item{display:flex;align-items:center;gap:7px;font-weight:600;color:var(--text);}
.legend-swatch{
  width:30px;height:16px;border-radius:3px;border:1px solid rgba(0,0,0,0.15);
  display:flex;align-items:center;justify-content:center;
  font-size:0.5rem;font-weight:800;color:rgba(0,0,0,0.4);
}
.legend-swatch.available{background:var(--available-bg);}
.legend-swatch.tentative{background:var(--tentative-bg);}
.legend-swatch.blocked{background:var(--blocked-bg);}

/* ── DATE PAGE ── */
.date-status-result{
  margin-top:22px;background:#fff;border:2px solid var(--border);
  border-radius:6px;padding:22px;display:none;
}
.date-status-result.show{display:block;animation:fadeIn 0.3s;}
.date-status-result h3{font-family:'Playfair Display',serif;font-size:1.1rem;margin-bottom:14px;color:var(--dark3);}
.slot-status-row{
  display:flex;align-items:center;gap:12px;margin-bottom:10px;
  padding:10px 14px;border-radius:4px;background:var(--cream2);border:1px solid var(--border);
}
.slot-status-row .slot-name{font-weight:700;min-width:45px;}

/* ── BOOKING FORM EMBED ── */
.booking-embed-wrap{
  background:#fff;border:2px solid var(--border);border-radius:8px;overflow:hidden;
}
.booking-embed-wrap iframe{
  width:100%;border:none;min-height:780px;display:block;
}
.gform-note{
  padding:14px 20px;background:var(--cream2);border-top:1px solid var(--border);
  font-size:0.82rem;color:#666;text-align:center;
}
.gform-note a{color:var(--dark3);font-weight:600;}

/* ── BOTTOM HOME BUTTON ── */
.bottom-home-link{
  margin-top:32px;padding-top:24px;border-top:2px dashed var(--border);text-align:center;
}
.btn-home-bottom{
  font-family:'DM Sans',sans-serif;font-size:0.95rem;font-weight:600;
  padding:12px 36px;border:2px solid var(--gold);background:var(--dark2);
  color:var(--gold-light);border-radius:4px;cursor:pointer;transition:all 0.2s;
}
.btn-home-bottom:hover{background:var(--gold);color:var(--dark);}

/* ── LOADING SPINNER ── */
.cal-loading{
  text-align:center;padding:40px;color:var(--dark3);
  font-family:'Playfair Display',serif;font-size:1rem;
}
.spinner{
  width:36px;height:36px;border:3px solid var(--border);
  border-top-color:var(--gold);border-radius:50%;
  animation:spin 0.8s linear infinite;margin:0 auto 14px;
}
@keyframes spin{to{transform:rotate(360deg);}}

/* ── APPS SCRIPT CONFIG BANNER ── */
.config-banner{
  background:#fff3e0;border:2px solid #ffb74d;border-radius:6px;
  padding:14px 20px;margin-bottom:20px;font-size:0.88rem;color:#7a4700;
  display:flex;align-items:flex-start;gap:10px;
}
.config-banner strong{display:block;margin-bottom:4px;}

@media(max-width:1000px){.three-cal-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:640px){
  .three-cal-grid{grid-template-columns:1fr;}
  .page{padding:18px 12px;}
  nav button{padding:8px 14px;font-size:0.8rem;}
  .site-header h1{font-size:1.2rem;}
  .login-card{padding:36px 24px 30px;}
}
</style>
</head>
<body>

<!-- ==================== LOGIN SCREEN ==================== -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">🏛️</div>
    <div class="login-title">HY One – HY Nine – Sriman<br>Booking System</div>
    <div class="login-sub">Sign in to manage hall bookings</div>
    <hr class="login-divider"/>
    <button class="google-btn" onclick="handleGoogleLogin()">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Sign in with Google
    </button>
    <div class="login-note">Access restricted to authorised staff only</div>
  </div>
</div>

<!-- ==================== MAIN APP ==================== -->
<div id="main-app">

  <header class="site-header">
    <div class="header-inner">
      <div style="width:140px;"></div>
      <h1>HY One – HY Nine – Sriman<span class="sub">Booking System</span></h1>
      <div class="user-info" id="user-info-bar"></div>
    </div>
  </header>

  <nav>
    <button class="active" onclick="showPage('home-page',this)">Home</button>
    <button onclick="showPage('overview-page',this)">Overview</button>
    <button onclick="showPage('date-page',this)">Date</button>
    <button onclick="showPage('booking-page',this)">Booking Form</button>
    <button class="reset-btn" onclick="resetApp()">Reset</button>
  </nav>

  <!-- ===== HOME PAGE ===== -->
  <div id="home-page" class="page active">
    <div class="nav-cards">
      <div class="nav-card" onclick="showPage('overview-page',null)">
        <div class="icon">📅</div>
        <h3>Overview</h3>
        <p>3-month calendar with AM/PM availability per hall</p>
      </div>
      <div class="nav-card" onclick="showPage('date-page',null)">
        <div class="icon">🔍</div>
        <h3>Date</h3>
        <p>Check availability for a specific date</p>
      </div>
      <div class="nav-card" onclick="showPage('booking-page',null)">
        <div class="icon">📝</div>
        <h3>Booking Form</h3>
        <p>Submit a new booking via Google Form</p>
      </div>
    </div>
  </div>

  <!-- ===== OVERVIEW PAGE ===== -->
  <div id="overview-page" class="page">
    <div class="section-title">Overview — Monthly Calendar</div>

    <div id="script-config-banner" class="config-banner" style="display:none;">
      ⚠️ <div><strong>Apps Script not configured.</strong>
      Paste your deployed Apps Script Web App URL in the settings below to sync with Google Sheets/Calendar.
      Calendar is showing local data only.</div>
    </div>

    <div class="overview-controls">
      <div class="form-group">
        <label>Convention Hall</label>
        <select id="ov-hall">
          <option value="">-- Select Hall --</option>
          <option value="HY One">HY One</option>
          <option value="HY Nine">HY Nine</option>
          <option value="Sriman">Sriman</option>
        </select>
      </div>
      <div class="form-group">
        <label>Month</label>
        <select id="ov-month">
          <option value="">-- Select Month --</option>
          <option value="0">January</option><option value="1">February</option>
          <option value="2">March</option><option value="3">April</option>
          <option value="4">May</option><option value="5">June</option>
          <option value="6">July</option><option value="7">August</option>
          <option value="8">September</option><option value="9">October</option>
          <option value="10">November</option><option value="11">December</option>
        </select>
      </div>
      <div class="form-group">
        <label>Year</label>
        <select id="ov-year"><option value="">-- Select Year --</option></select>
      </div>
      <button class="btn btn-primary" onclick="renderOverviewCalendar()">View Calendar</button>
    </div>

    <div id="overview-calendar"></div>

    <div class="cal-legend" id="cal-legend" style="display:none;">
      <div class="legend-item"><div class="legend-swatch available">AM<br>PM</div>Available</div>
      <div class="legend-item"><div class="legend-swatch tentative">AM<br>PM</div>Tentative</div>
      <div class="legend-item"><div class="legend-swatch blocked">AM<br>PM</div>Blocked</div>
      <div class="legend-item">
        <span style="background:#1a237e;color:#fff;font-size:0.7rem;font-weight:700;padding:2px 7px;border-radius:3px;">🏦</span>Bank Holiday
      </div>
      <div class="legend-item">
        <span style="background:#f57f17;color:#fff;font-size:0.7rem;font-weight:700;padding:2px 7px;border-radius:3px;">🕉</span>Hindu Festival
      </div>
    </div>
  </div>

  <!-- ===== DATE PAGE ===== -->
  <div id="date-page" class="page">
    <div class="section-title">Check Date Availability</div>
    <div style="background:#fff;border:2px solid var(--border);border-radius:6px;padding:26px;max-width:480px;">
      <div class="form-group">
